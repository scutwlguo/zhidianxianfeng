{
  "schema_version": "2.1",
  "profile": "conservative_reference_rules",
  "description": "用于GPT分析居民用电行为的保守型参考规则表（经验规则，可按地区、季节与家庭习惯调整）",
  "usage_principles": [
    "本表为经验性参考规则，不构成刚性判定标准",
    "运行时段仅作为辅助判断依据，不应单独用于认定异常",
    "优先依据单次时长、单日电量、持续低功率运行、重复启停等强特征进行分析",
    "仅当用户明确执行峰谷分时电价时，才将时段迁移作为核心节能建议",
    "节能建议应尽量面向具体设备、具体行为，避免脱离家庭生活场景的机械化判断",
    "若设备行为既可能由生活习惯解释，也可能反映低效运行，应采用保守措辞，如“可能存在”“建议关注”“可进一步确认”"
  ],
  "global_rules": {
    "price_per_kwh": 0.7,
    "late_night_period": [
      "23:00",
      "06:00"
    ],
    "high_load_parallel_count_threshold": 2,
    "high_load_appliance_codes": [
      "AC",
      "BL",
      "DY",
      "WM",
      "DW",
      "EH",
      "MW",
      "KT",
      "RC",
      "FG",
      "SV"
    ],
    "weak_signal_only_fields": [
      "typical_windows",
      "late_night_period",
      "high_load_parallel_count_threshold"
    ],
    "strong_signal_priority_fields": [
      "max_single_on_minutes",
      "max_daily_on_minutes",
      "abnormal_daily_energy_kwh_hint"
    ],
    "report_style_rules": [
      "优先指出最值得优化的1到3个设备，不平均分配建议",
      "避免仅凭夜间使用或非典型时段使用直接判定异常",
      "建议优先从缩短时长、减少保温/待机、优化设定参数、合并运行次数四类方式展开"
    ]
  },
